# Сервис
APP_HOST=0.0.0.0
APP_PORT=8000
APP_WORKERS=1
APP_RELOAD=false
APP_LOG_LEVEL=info

# Безопасность, если появится
SECRET_KEY=your-secret-key-here
API_KEY=your-api-key-here
# Список разрешённых origins через запятую
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# GPU
# Индекс GPU для генерации (-1 = CPU)
GENERATION_GPU=0
# Индекс GPU для судьи Qwen2-VL (-1 = CPU)
JUDGE_GPU=1
# Индекс GPU для метрик (LPIPS, InsightFace)
METRICS_GPU=2

# Пути (относительно корня проекта)
DATASET_DIR=dataset/Humans
OUTPUT_DIR=outputs
CHECKPOINT_DIR=notebooks/dpo_checkpoints
MEAN_FACE_PATH=configs/mean_face.json
FEATURE_MAPS_DIR=configs/controlnet/feature_maps
PROMPT_PARAMS_DIR=configs/controlnet/prompt_params

# HuggingFace 
# Токен для скачивания моделей (если нужна авторизация)
HF_TOKEN=your-huggingface-token-here
# Локальный кэш моделей HF
HF_HOME=artifacts/hf_cache

# Внешние API 
# Если использовать GPT-4o вместо Qwen как судью
OPENAI_API_KEY=your-openai-key-here